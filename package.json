{
  "name": "goodraves",
  "version": "1.0.0",
  "description": "Festival & Party Tracker",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate": "node-pg-migrate up --envPath .env -m migrations --no-lock --ignore-pattern '\\..*|.*\\.md'",
    "db:migrate:down": "node-pg-migrate down --envPath .env -m migrations --no-lock --ignore-pattern '\\..*|.*\\.md'",
    "db:migrate:create": "node-pg-migrate create -m migrations -j sql"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "next": "^15.3.2",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "typescript": "^5.8.3"
  }
}
