{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-push-account.sh",
            "statusMessage": "Checking gh account before push"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-doc-sync.sh",
            "statusMessage": "Checking docs are in sync with code changes"
          }
        ]
      }
    ]
  }
}
